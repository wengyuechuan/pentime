{
  "segments": [
    {
      "id": "gateway-v1.8.1",
      "type": "legacy",
      "match": {
        "exact": ["1.8.1"]
      },
      "lockedVersion": "1.8.1",
      "minCompatibleVersion": "1.0.0",
      "description": "Gateway version - all users below v1.8.1 must upgrade to v1.8.1 first",
      "channelTemplates": {
        "latest": {
          "feedTemplates": {
            "github": "https://pentime-new.com/pen-time/releases/{{tag}}",
            "gitcode": "https://pentime-new.com/pen-time/releases/{{tag}}"
          }
        }
      }
    },
    {
      "id": "current-v1",
      "type": "latest",
      "match": {
